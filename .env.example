# Firebase web config. Copy this file to `.env` and paste your project's values.
# Firebase Console → Project settings (gear) → Your apps → Web app →
# SDK setup and configuration → copy the `firebaseConfig` object.
#
# These are client-side web config values (they ship in the browser bundle by
# design). Security comes from Firestore/Storage Rules + API key restrictions +
# App Check, NOT from hiding these values. Leaving them blank runs the app in
# local mode (data stored in the browser's localStorage).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
